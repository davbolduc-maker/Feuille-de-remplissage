    const allPossibleFormats = ["20 RG", "20 KS", "25 RG", "25 KS", "40 RG", "40 KS", "50 RG", "50 KS"];

    // Génération dynamique de l'interface mobile
    function buildMobileInterface() {
        productsData.forEach((product, idx) => {
            const section = document.getElementById(`section-${product.mfg}`);
            if (!section) return;

            const card = document.createElement("div");
            card.className = "product-card";

            const nameDiv = document.createElement("div");
            nameDiv.className = "product-name";
            nameDiv.innerText = product.name;
            card.appendChild(nameDiv);

            const grid = document.createElement("div");
            grid.className = "formats-grid";

            allPossibleFormats.forEach(format => {
                const isAvailable = !!product.formats[format];
                
                const optionDiv = document.createElement("div");
                optionDiv.className = "format-option";

                const checkbox = document.createElement("input");
                checkbox.type = "checkbox";
                checkbox.setAttribute("data-product", product.name);
                checkbox.setAttribute("data-format", format);
                if (!isAvailable) checkbox.disabled = true;

                const label = document.createElement("label");
                label.className = "format-label";
                label.innerText = format;

                optionDiv.appendChild(checkbox);
                optionDiv.appendChild(label);
                grid.appendChild(optionDiv);
            });

            card.appendChild(grid);
            section.appendChild(card);
        });
        updateEmailAddress();
    }

    function updateEmailAddress() {
        var select = document.getElementById("siteSelect");
        var email = select.value;
        // Supprime le point final s'il existe (correctif pour le site 1522)
        if (email.endsWith('.')) {
            email = email.slice(0, -1);
        }
        document.getElementById("emailDisplay").innerText = "Courriel associé : " + email;
    }

    function clearAllCheckboxes() {
        var checkboxes = document.querySelectorAll('input[type="checkbox"]');
        checkboxes.forEach(function(cb) {
            if (!cb.disabled) cb.checked = false;
        });
    }

    function generateAndSendEmail() {
        var select = document.getElementById("siteSelect");
        var siteNumber = select.options[select.selectedIndex].text;
        var destinationEmail = select.value;

        // Nettoyage automatique du point final pour éviter un rejet d'envoi
        if (destinationEmail.endsWith('.')) {
            destinationEmail = destinationEmail.slice(0, -1);
        }

        var now = new Date();
        var dd = String(now.getDate()).padStart(2, '0');
        var mm = String(now.getMonth() + 1).padStart(2, '0');
        var yyyy = now.getFullYear();
        var formattedDate = dd + '/' + mm + '/' + yyyy;

        var checkedItems = document.querySelectorAll('input[type="checkbox"]:checked');
        
        if (checkedItems.length === 0) {
            alert("Attention : Veuillez sélectionner au moins un produit avant d'envoyer la commande.");
            return;
        }

        var itemsText = "";
        checkedItems.forEach(function(item) {
            var pName = item.getAttribute("data-product");
            var fName = item.getAttribute("data-format");
            itemsText += "- " + pName + " (" + fName + ")\n";
        });

        var mailSubject = "Commande de produits - Site #" + siteNumber + " - " + formattedDate;
        var mailBody = "Bonjour,\n\nVoici la liste des produits cochés à commander pour le site #" + siteNumber + " en date du " + formattedDate + " :\n\n" + itemsText + "\nMerkxi et bonne journée !";

        var mailtoLink = "mailto:" + destinationEmail + 
                         "?subject=" + encodeURIComponent(mailSubject) + 
                         "&body=" + encodeURIComponent(mailBody);

        window.location.href = mailtoLink;
    }

    // Lancer la construction de l'interface au chargement
    window.onload = buildMobileInterface;
</script>

</body>
</html>
